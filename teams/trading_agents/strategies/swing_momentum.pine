// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © AI-Agents-Platform — Swing Momentum Strategy
// Designed for BTC/USDT on 4H timeframe (Binance USDT-M Futures)
// Bidirectional: RSI 50-line crossover with EMA trend filter + volume + ATR trail

//@version=6
strategy("Swing Momentum [AI-Agents]", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_value=0.04)

// ── Inputs ──────────────────────────────────────────────────────────
rsiLen       = input.int(18,    "RSI Length",            minval=5)
rsiBull      = input.float(50.0,"RSI Bullish Threshold", minval=40.0, step=1.0, tooltip="Long when RSI crosses above this level")
rsiBear      = input.float(50.0,"RSI Bearish Threshold", minval=40.0, step=1.0, tooltip="Short when RSI crosses below this level")
emaLen       = input.int(50,    "EMA Trend Filter Length", minval=10)
volThresh    = input.float(1.0, "Volume Threshold (× MA)", minval=0.5, step=0.1)
volMALen     = input.int(20,    "Volume MA Length",       minval=5)
atrLen       = input.int(14,    "ATR Length",             minval=1)
atrTrailMult = input.float(2.5, "ATR Trailing Stop Multiple", minval=0.5, step=0.5)
webhookSecret = input.string("", "Webhook Secret",       tooltip="Shared secret for webhook authentication")

// ── Calculations ────────────────────────────────────────────────────
rsi     = ta.rsi(close, rsiLen)
emaTrend = ta.ema(close, emaLen)
atr     = ta.atr(atrLen)
volMA   = ta.sma(volume, volMALen)

volumeOk = volume > volMA * volThresh

bullCross = ta.crossover(rsi, rsiBull)
bearCross = ta.crossunder(rsi, rsiBear)

aboveEMA = close > emaTrend
belowEMA = close < emaTrend

// ── Entry Conditions ────────────────────────────────────────────────
longEntry  = bullCross and volumeOk and aboveEMA
shortEntry = bearCross and volumeOk and belowEMA

// ── Trailing Stop ───────────────────────────────────────────────────
var float trailLong  = na
var float trailShort = na

if strategy.position_size > 0
    newTrail = close - atr * atrTrailMult
    trailLong := na(trailLong) ? newTrail : math.max(trailLong, newTrail)
else
    trailLong := na

if strategy.position_size < 0
    newTrailS = close + atr * atrTrailMult
    trailShort := na(trailShort) ? newTrailS : math.min(trailShort, newTrailS)
else
    trailShort := na

// ── Strategy Execution ──────────────────────────────────────────────
alertMsg(action) => '{"secret":"' + webhookSecret + '","strategy_name":"swing_momentum","action":"' + action + '","ticker":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"' + str.tostring(time) + '"}'

if longEntry and strategy.position_size <= 0
    strategy.entry("SM Long", strategy.long, alert_message=alertMsg("buy"))

if shortEntry and strategy.position_size >= 0
    strategy.entry("SM Short", strategy.short, alert_message=alertMsg("sell"))

if strategy.position_size > 0 and (close <= trailLong or bearCross)
    strategy.close("SM Long", comment="Trail/RSI", alert_message=alertMsg("close_buy"))

if strategy.position_size < 0 and (close >= trailShort or bullCross)
    strategy.close("SM Short", comment="Trail/RSI", alert_message=alertMsg("close_sell"))

// ── Plots ───────────────────────────────────────────────────────────
plot(emaTrend, "EMA Trend", color=color.orange, linewidth=2)
plot(strategy.position_size > 0 ? trailLong : na, "Trail Long", color=color.green, style=plot.style_linebr, linewidth=1)
plot(strategy.position_size < 0 ? trailShort : na, "Trail Short", color=color.red, style=plot.style_linebr, linewidth=1)

bgcolor(longEntry ? color.new(color.green, 90) : shortEntry ? color.new(color.red, 90) : na, title="Entry Signal")
