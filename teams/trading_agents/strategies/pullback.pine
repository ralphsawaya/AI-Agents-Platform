// © AI-Agents-Platform — Trend Pullback Strategy (v2)
// Designed for BTC/USDT on 1H timeframe (Binance USDT-M Futures)
// Bidirectional: trades pullbacks within established trends (long + short)
// Internal ADX + EMA slope filters for quality control

//@version=6
strategy("Trend Pullback [AI-Agents]", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_value=0.04)

// ── Inputs ──────────────────────────────────────────────────────────
emaSlow        = input.int(50,   "Slow EMA (Trend Filter)",     minval=20, tooltip="Determines trend direction via slope")
emaFast        = input.int(8,    "Fast EMA (Pullback Level)",   minval=5,  tooltip="Price pulls back to this level")
trendLookback  = input.int(12,   "Trend Slope Lookback",        minval=4,  tooltip="Number of bars to measure EMA slope")
minSlope       = input.float(0.15, "Min EMA Slope % (trend strength)", minval=0.01, step=0.05, tooltip="Minimum slope to confirm trend")
adxMin         = input.float(20.0, "Min ADX (trend confirmation)", minval=10.0, step=1.0, tooltip="ADX must be above this for trend confirmation")
volThresh      = input.float(1.0, "Volume Threshold (× MA)",    minval=0.5, step=0.1)
volMALen       = input.int(20,   "Volume MA Length",             minval=5)
atrLen         = input.int(14,   "ATR Length",                   minval=1)
atrTrailMult   = input.float(1.0, "ATR Trailing Stop Multiple", minval=0.5, step=0.1)
cooldownBars   = input.int(12,   "Cooldown Bars After Exit",    minval=0, tooltip="Minimum bars between trades")
maxHoldBars    = input.int(48,   "Max Hold Bars",               minval=10, tooltip="Force exit after N bars")
webhookSecret  = input.string("","Webhook Secret",              tooltip="Shared secret for webhook authentication")

// ── Calculations ────────────────────────────────────────────────────
slowEMA = ta.ema(close, emaSlow)
fastEMA = ta.ema(close, emaFast)
atr     = ta.atr(atrLen)
rsi     = ta.rsi(close, 14)
volMA   = ta.sma(volume, volMALen)
[diPlus, diMinus, adxVal] = ta.dmi(14, 14)

slopeRaw = trendLookback > 0 ? (slowEMA - slowEMA[trendLookback]) / slowEMA[trendLookback] * 100 : 0
trendUp = slopeRaw > minSlope and adxVal > adxMin
trendDn = slopeRaw < -minSlope and adxVal > adxMin

volumeOk = volume > volMA * volThresh

pulledBackUp = close > fastEMA and close[1] <= fastEMA[1]
pulledBackDn = close < fastEMA and close[1] >= fastEMA[1]

rsiWasLow  = ta.lowest(rsi, 4) < 40
rsiWasHigh = ta.highest(rsi, 4) > 60

// Cooldown tracking
var int barsSinceExit = 999
if strategy.position_size == 0 and strategy.position_size[1] != 0
    barsSinceExit := 0
else if strategy.position_size == 0
    barsSinceExit := barsSinceExit + 1

cooldownOk = barsSinceExit >= cooldownBars

// Hold time tracking
var int barsHeld = 0
if strategy.position_size != 0
    barsHeld := barsHeld + 1
else
    barsHeld := 0

// ── Entry Conditions ────────────────────────────────────────────────
longEntry  = trendUp and pulledBackUp and rsiWasLow and rsi > 40 and volumeOk and cooldownOk
shortEntry = trendDn and pulledBackDn and rsiWasHigh and rsi < 60 and volumeOk and cooldownOk

// ── Trailing Stop ───────────────────────────────────────────────────
var float trailLong  = na
var float trailShort = na

if strategy.position_size > 0
    newTrail = close - atr * atrTrailMult
    trailLong := na(trailLong) ? newTrail : math.max(trailLong, newTrail)
else
    trailLong := na

if strategy.position_size < 0
    newTrailS = close + atr * atrTrailMult
    trailShort := na(trailShort) ? newTrailS : math.min(trailShort, newTrailS)
else
    trailShort := na

// ── Strategy Execution ──────────────────────────────────────────────
alertMsg(action) => '{"secret":"' + webhookSecret + '","strategy_name":"pullback","action":"' + action + '","ticker":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"' + str.tostring(time) + '"}'

if longEntry and strategy.position_size <= 0
    strategy.entry("Pullback Long", strategy.long, alert_message=alertMsg("buy"))

if shortEntry and strategy.position_size >= 0
    strategy.entry("Pullback Short", strategy.short, alert_message=alertMsg("sell"))

if strategy.position_size > 0 and (close <= trailLong or barsHeld >= maxHoldBars)
    strategy.close("Pullback Long", comment="Trail/MaxHold", alert_message=alertMsg("close_buy"))

if strategy.position_size < 0 and (close >= trailShort or barsHeld >= maxHoldBars)
    strategy.close("Pullback Short", comment="Trail/MaxHold", alert_message=alertMsg("close_sell"))

// ── Plots ───────────────────────────────────────────────────────────
plot(slowEMA, "Slow EMA (Trend)", color=color.orange, linewidth=2)
plot(fastEMA, "Fast EMA (Pullback)", color=color.blue, linewidth=1)
plot(strategy.position_size > 0 ? trailLong : na, "Trail Long", color=color.green, style=plot.style_linebr, linewidth=1)
plot(strategy.position_size < 0 ? trailShort : na, "Trail Short", color=color.red, style=plot.style_linebr, linewidth=1)

bgcolor(trendUp ? color.new(color.green, 95) : trendDn ? color.new(color.red, 95) : na, title="Trend Direction")
bgcolor(longEntry ? color.new(color.green, 85) : shortEntry ? color.new(color.red, 85) : na, title="Entry Signal")
