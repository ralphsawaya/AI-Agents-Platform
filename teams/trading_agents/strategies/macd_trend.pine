// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © AI-Agents-Platform — MACD Trend Strategy (Portfolio Diversifier)
// Designed for BTC/USDT on 4H timeframe (Binance USDT-M Futures)
// Bidirectional: MACD histogram sign-change with EMA trend filter
// OOS +8.3% return | 73% WF efficiency

//@version=6
strategy("MACD Trend [AI-Agents]", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_value=0.04)

// ── Inputs ──────────────────────────────────────────────────────────
macdFastLen  = input.int(12,  "MACD Fast Length",  minval=1)
macdSlowLen  = input.int(26,  "MACD Slow Length",  minval=1)
macdSignalLen = input.int(9,  "MACD Signal Length", minval=1)
atrLen       = input.int(14,  "ATR Length",        minval=1)
atrTrailMult = input.float(3.0, "ATR Trailing Stop Multiplier", minval=0.5, step=0.5)
webhookSecret = input.string("", "Webhook Secret", tooltip="Shared secret for webhook authentication")

// ── Calculations ────────────────────────────────────────────────────
[macdLine, signalLine, macdHist] = ta.macd(close, macdFastLen, macdSlowLen, macdSignalLen)
emaTrend = ta.ema(close, macdSlowLen)
atr      = ta.atr(atrLen)

// ── Conditions ──────────────────────────────────────────────────────
histBullCross = ta.crossover(macdHist, 0)
histBearCross = ta.crossunder(macdHist, 0)

longEntry  = histBullCross and close > emaTrend
shortEntry = histBearCross and close < emaTrend

// ── Trailing Stop ───────────────────────────────────────────────────
var float trailLong  = na
var float trailShort = na

if strategy.position_size > 0
    newTrail = close - atr * atrTrailMult
    trailLong := na(trailLong) ? newTrail : math.max(trailLong, newTrail)
else
    trailLong := na

if strategy.position_size < 0
    newTrailS = close + atr * atrTrailMult
    trailShort := na(trailShort) ? newTrailS : math.min(trailShort, newTrailS)
else
    trailShort := na

// ── Strategy Execution ──────────────────────────────────────────────
alertMsg(action) => '{"secret":"' + webhookSecret + '","strategy_name":"macd_trend","action":"' + action + '","ticker":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"' + str.tostring(time) + '"}'

if longEntry and strategy.position_size <= 0
    if strategy.position_size < 0
        strategy.close("MT Short", comment="MACD Flip", alert_message=alertMsg("close_sell"))
    strategy.entry("MT Long", strategy.long, alert_message=alertMsg("buy"))

if shortEntry and strategy.position_size >= 0
    if strategy.position_size > 0
        strategy.close("MT Long", comment="MACD Flip", alert_message=alertMsg("close_buy"))
    strategy.entry("MT Short", strategy.short, alert_message=alertMsg("sell"))

if strategy.position_size > 0 and not na(trailLong) and close <= trailLong
    strategy.close("MT Long", comment="Trail Stop", alert_message=alertMsg("close_buy"))

if strategy.position_size < 0 and not na(trailShort) and close >= trailShort
    strategy.close("MT Short", comment="Trail Stop", alert_message=alertMsg("close_sell"))

// ── Plots ───────────────────────────────────────────────────────────
plot(emaTrend, "EMA Trend", color=color.orange, linewidth=2)
plot(strategy.position_size > 0 ? trailLong : na, "Trail Long", color=color.green, style=plot.style_linebr, linewidth=1)
plot(strategy.position_size < 0 ? trailShort : na, "Trail Short", color=color.red, style=plot.style_linebr, linewidth=1)

bgcolor(longEntry ? color.new(color.green, 90) : shortEntry ? color.new(color.red, 90) : na, title="Entry Signal")
