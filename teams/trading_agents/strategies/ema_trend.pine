// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © AI-Agents-Platform — EMA Trend Strategy (Walk-Forward Validated)
// Designed for BTC/USDT on 4H timeframe (Binance USDT-M Futures)
// Bidirectional: pure EMA crossover with ATR trailing stop
// OOS Sharpe 1.14 | +60.4% return | 390% WF efficiency

//@version=6
strategy("EMA Trend [AI-Agents]", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_value=0.04)

// ── Inputs ──────────────────────────────────────────────────────────
emaFastLen   = input.int(12,  "EMA Fast Length",  minval=1)
emaSlowLen   = input.int(50,  "EMA Slow Length",  minval=1)
atrLen       = input.int(14,  "ATR Length",       minval=1)
atrTrailMult = input.float(3.5, "ATR Trailing Stop Multiplier", minval=0.5, step=0.5)
webhookSecret = input.string("", "Webhook Secret", tooltip="Shared secret for webhook authentication")

// ── Calculations ────────────────────────────────────────────────────
emaFast = ta.ema(close, emaFastLen)
emaSlow = ta.ema(close, emaSlowLen)
atr     = ta.atr(atrLen)

// ── Conditions ──────────────────────────────────────────────────────
bullCross = ta.crossover(emaFast, emaSlow)
bearCross = ta.crossunder(emaFast, emaSlow)

// ── Trailing Stop ───────────────────────────────────────────────────
var float trailLong  = na
var float trailShort = na

if strategy.position_size > 0
    newTrail = close - atr * atrTrailMult
    trailLong := na(trailLong) ? newTrail : math.max(trailLong, newTrail)
else
    trailLong := na

if strategy.position_size < 0
    newTrailS = close + atr * atrTrailMult
    trailShort := na(trailShort) ? newTrailS : math.min(trailShort, newTrailS)
else
    trailShort := na

// ── Strategy Execution ──────────────────────────────────────────────
alertMsg(action) => '{"secret":"' + webhookSecret + '","strategy_name":"ema_trend","action":"' + action + '","ticker":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"' + str.tostring(time) + '"}'

if bullCross
    if strategy.position_size < 0
        strategy.close("ET Short", comment="EMA Flip", alert_message=alertMsg("close_sell"))
    strategy.entry("ET Long", strategy.long, alert_message=alertMsg("buy"))

if bearCross
    if strategy.position_size > 0
        strategy.close("ET Long", comment="EMA Flip", alert_message=alertMsg("close_buy"))
    strategy.entry("ET Short", strategy.short, alert_message=alertMsg("sell"))

if strategy.position_size > 0 and not na(trailLong) and close <= trailLong
    strategy.close("ET Long", comment="Trail Stop", alert_message=alertMsg("close_buy"))

if strategy.position_size < 0 and not na(trailShort) and close >= trailShort
    strategy.close("ET Short", comment="Trail Stop", alert_message=alertMsg("close_sell"))

// ── Plots ───────────────────────────────────────────────────────────
plot(emaFast, "EMA Fast", color=color.blue, linewidth=2)
plot(emaSlow, "EMA Slow", color=color.orange, linewidth=2)
plot(strategy.position_size > 0 ? trailLong : na, "Trail Long", color=color.green, style=plot.style_linebr, linewidth=1)
plot(strategy.position_size < 0 ? trailShort : na, "Trail Short", color=color.red, style=plot.style_linebr, linewidth=1)

bgcolor(bullCross ? color.new(color.green, 90) : bearCross ? color.new(color.red, 90) : na, title="Entry Signal")
