// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © AI-Agents-Platform — RSI Momentum Strategy (Walk-Forward Validated)
// Designed for BTC/USDT on 4H timeframe (Binance USDT-M Futures)
// Bidirectional: RSI 50-line crossover with EMA trend filter, trail-only exit
// OOS Sharpe 1.37 | +88.5% return | 124% WF efficiency | Trail-only exit

//@version=6
strategy("RSI Momentum [AI-Agents]", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_value=0.04)

// ── Inputs ──────────────────────────────────────────────────────────
rsiLen       = input.int(14,  "RSI Length",       minval=1)
emaLen       = input.int(50,  "EMA Length",       minval=1)
atrLen       = input.int(14,  "ATR Length",       minval=1)
atrTrailMult = input.float(3.0, "ATR Trailing Stop Multiplier", minval=0.5, step=0.5)
webhookSecret = input.string("", "Webhook Secret", tooltip="Shared secret for webhook authentication")

// ── Calculations ────────────────────────────────────────────────────
rsiVal  = ta.rsi(close, rsiLen)
emaVal  = ta.ema(close, emaLen)
atr     = ta.atr(atrLen)

// ── Conditions ──────────────────────────────────────────────────────
rsiBullCross = ta.crossover(rsiVal, 50)
rsiBearCross = ta.crossunder(rsiVal, 50)

longEntry  = rsiBullCross and close > emaVal
shortEntry = rsiBearCross and close < emaVal

// ── Trailing Stop ───────────────────────────────────────────────────
var float trailLong  = na
var float trailShort = na

if strategy.position_size > 0
    newTrail = close - atr * atrTrailMult
    trailLong := na(trailLong) ? newTrail : math.max(trailLong, newTrail)
else
    trailLong := na

if strategy.position_size < 0
    newTrailS = close + atr * atrTrailMult
    trailShort := na(trailShort) ? newTrailS : math.min(trailShort, newTrailS)
else
    trailShort := na

// ── Strategy Execution ──────────────────────────────────────────────
alertMsg(action) => '{"secret":"' + webhookSecret + '","strategy_name":"rsi_momentum","action":"' + action + '","ticker":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"' + str.tostring(time) + '"}'

if longEntry and strategy.position_size == 0
    strategy.entry("RM Long", strategy.long, alert_message=alertMsg("buy"))

if shortEntry and strategy.position_size == 0
    strategy.entry("RM Short", strategy.short, alert_message=alertMsg("sell"))

if strategy.position_size > 0 and not na(trailLong) and close <= trailLong
    strategy.close("RM Long", comment="Trail Stop", alert_message=alertMsg("close_buy"))

if strategy.position_size < 0 and not na(trailShort) and close >= trailShort
    strategy.close("RM Short", comment="Trail Stop", alert_message=alertMsg("close_sell"))

// ── Plots ───────────────────────────────────────────────────────────
plot(emaVal, "EMA", color=color.orange, linewidth=2)
plot(strategy.position_size > 0 ? trailLong : na, "Trail Long", color=color.green, style=plot.style_linebr, linewidth=1)
plot(strategy.position_size < 0 ? trailShort : na, "Trail Short", color=color.red, style=plot.style_linebr, linewidth=1)

bgcolor(longEntry ? color.new(color.green, 90) : shortEntry ? color.new(color.red, 90) : na, title="Entry Signal")
