// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © AI-Agents-Platform — Scalping Strategy
// Designed for BTC/USDT on 1H timeframe
// Webhook-enabled for automated trading via TradingView alerts

//@version=6
strategy("Scalping [AI-Agents]", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_value=0.1)

// ── Inputs ──────────────────────────────────────────────────────────
emaLen         = input.int(9,    "EMA Length",                  minval=1)
atrLen         = input.int(14,   "ATR Length",                  minval=1)
atrSlMult      = input.float(0.5, "ATR Stop Loss Multiple",    minval=0.1, step=0.1)
atrTpMult      = input.float(1.0, "ATR Take Profit Multiple",  minval=0.1, step=0.1)
volSpikeThresh = input.float(2.0, "Volume Spike Threshold (x MA)", minval=1.0, step=0.5)
volMALen       = input.int(20,   "Volume MA Length",            minval=5)
useTimeFilter  = input.bool(true, "Enable Time Filter",        tooltip="Avoid low-volume periods")
sessionStart   = input.int(8,    "Session Start Hour (UTC)",   minval=0, maxval=23)
sessionEnd     = input.int(22,   "Session End Hour (UTC)",     minval=0, maxval=23)
webhookSecret  = input.string("", "Webhook Secret",            tooltip="Shared secret for webhook authentication")

// ── Calculations ────────────────────────────────────────────────────
ema    = ta.ema(close, emaLen)
atr    = ta.atr(atrLen)
volMA  = ta.sma(volume, volMALen)

// VWAP (built-in)
vwapVal = ta.vwap(hlc3)

// Volume spike detection
volumeSpike = volume > volMA * volSpikeThresh

// Time filter (UTC hours)
currentHour = hour(time, "UTC")
inSession   = not useTimeFilter or (currentHour >= sessionStart and currentHour < sessionEnd)

// Price relative to VWAP and EMA
aboveVwap = close > vwapVal
belowVwap = close < vwapVal
emaBullish = close > ema
emaBearish = close < ema

// ── Conditions ──────────────────────────────────────────────────────
// Long scalp: price above VWAP + above EMA + volume spike + in session
longScalp  = aboveVwap and emaBullish and volumeSpike and inSession

// Exit: price drops below VWAP or EMA, or TP/SL hit
longExit = belowVwap or emaBearish

// Stop-loss and take-profit levels
var float entryPrice = na
var float slLevel    = na
var float tpLevel    = na

if strategy.position_size > 0 and strategy.position_size[1] <= 0
    entryPrice := strategy.position_avg_price
    slLevel    := entryPrice - atr * atrSlMult
    tpLevel    := entryPrice + atr * atrTpMult
else if strategy.position_size <= 0
    entryPrice := na
    slLevel    := na
    tpLevel    := na

slHit = strategy.position_size > 0 and not na(slLevel) and close <= slLevel
tpHit = strategy.position_size > 0 and not na(tpLevel) and close >= tpLevel

// ── Strategy Execution ──────────────────────────────────────────────
if longScalp and strategy.position_size <= 0
    strategy.entry("Scalp Long", strategy.long, alert_message='{"secret":"' + webhookSecret + '","strategy_name":"scalping","action":"buy","ticker":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"' + str.tostring(time) + '"}')

if longExit and strategy.position_size > 0
    strategy.close("Scalp Long", comment="VWAP/EMA Exit", alert_message='{"secret":"' + webhookSecret + '","strategy_name":"scalping","action":"sell","ticker":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"' + str.tostring(time) + '"}')

if tpHit
    strategy.close("Scalp Long", comment="Take Profit", alert_message='{"secret":"' + webhookSecret + '","strategy_name":"scalping","action":"sell","ticker":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"' + str.tostring(time) + '"}')

if slHit
    strategy.close("Scalp Long", comment="Stop Loss", alert_message='{"secret":"' + webhookSecret + '","strategy_name":"scalping","action":"sell","ticker":"' + syminfo.ticker + '","price":"' + str.tostring(close) + '","time":"' + str.tostring(time) + '"}')

// ── Plots ───────────────────────────────────────────────────────────
plot(ema,     "EMA",  color=color.blue,   linewidth=2)
plot(vwapVal, "VWAP", color=color.purple, linewidth=2)
plot(strategy.position_size > 0 ? slLevel : na, "Stop Loss",   color=color.red,   style=plot.style_linebr, linewidth=1)
plot(strategy.position_size > 0 ? tpLevel : na, "Take Profit", color=color.green, style=plot.style_linebr, linewidth=1)

bgcolor(longScalp  ? color.new(color.green, 90) : na, title="Scalp Entry")
bgcolor(volumeSpike ? color.new(color.yellow, 95) : na, title="Volume Spike")

// Session background
bgcolor(not inSession ? color.new(color.gray, 95) : na, title="Off Session")
