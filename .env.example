# Groq API key (used by team_ab agents)
GROQ_API_KEY=your_groq_api_key_here

# Anthropic API key (used by trading agents)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Binance API keys (Spot trading)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# TradingView webhook shared secret
TRADINGVIEW_WEBHOOK_SECRET=your_webhook_secret_here

# Trading settings
# TRADING_ENABLED=true
# TRADING_DRY_RUN=true
# TRADING_MAX_DAILY_TRADES=50
# TRADING_DUPLICATE_WINDOW_SECONDS=60

# MongoDB connection (defaults to localhost if not set)
# MONGODB_URI=mongodb://localhost:27017

# LLM settings (optional overrides)
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_TEMPERATURE=0.3
# MAX_TOKENS=2048
